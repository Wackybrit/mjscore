{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "CommonJS",
    "target": "ES2022",

    "types": ["node"],

    "sourceMap": true,
    "strict": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "esModuleInterop": true,

    "skipLibCheck": true
  },

  "include": [
    "src/**/*"
  ]
}